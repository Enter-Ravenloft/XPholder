<%- include('partials/head', { title: 'Select Server' }) %>
<%- include('partials/nav') %>

<main class="max-w-lg mx-auto px-4 py-16">
  <h1 class="text-2xl font-bold mb-6 text-center">Select a Server</h1>

  <% if (guilds.length === 0) { %>
    <p class="text-gray-400 text-center">You don't have access to any registered XPholder servers.</p>
  <% } else { %>
    <div class="space-y-3">
      <% guilds.forEach(guild => { %>
      <form method="POST" action="/select-guild">
        <input type="hidden" name="guildId" value="<%= guild.id %>">
        <input type="hidden" name="guildName" value="<%= guild.name %>">
        <button type="submit" class="w-full flex items-center space-x-4 bg-gray-800 hover:bg-gray-700 border border-gray-700 rounded-lg p-4 transition">
          <% if (guild.icon) { %>
            <img src="https://cdn.discordapp.com/icons/<%= guild.id %>/<%= guild.icon %>.png?size=64" alt="" class="w-10 h-10 rounded-full">
          <% } else { %>
            <div class="w-10 h-10 rounded-full bg-gray-600 flex items-center justify-center text-sm font-bold"><%= guild.name.charAt(0) %></div>
          <% } %>
          <span class="text-lg"><%= guild.name %></span>
        </button>
      </form>
      <% }) %>
    </div>
  <% } %>
</main>

<%- include('partials/foot') %>
