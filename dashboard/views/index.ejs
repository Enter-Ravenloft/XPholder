<%- include('partials/head', { title: 'Dashboard' }) %>
<%- include('partials/nav') %>

<main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <h1 class="text-2xl font-bold mb-8">Dashboard</h1>

  <!-- Server activity -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
    <div class="bg-gray-800 rounded-lg p-4 border border-gray-700">
      <div class="text-2xl font-bold"><%= playerStats.total_members %></div>
      <div class="text-sm text-gray-400">Total Members</div>
    </div>
    <div class="bg-gray-800 rounded-lg p-4 border border-gray-700">
      <div class="text-2xl font-bold text-green-400"><%= playerStats.active_members %></div>
      <div class="text-sm text-gray-400">Active</div>
    </div>
    <div class="bg-gray-800 rounded-lg p-4 border border-gray-700">
      <div class="text-2xl font-bold text-yellow-400"><%= parseInt(playerStats.inactive_60) + parseInt(playerStats.inactive_90) %></div>
      <div class="text-sm text-gray-400">Inactive (60-90d)</div>
    </div>
    <div class="bg-gray-800 rounded-lg p-4 border border-gray-700">
      <div class="text-2xl font-bold text-red-400"><%= parseInt(playerStats.inactive_180) + parseInt(playerStats.inactive_365) %></div>
      <div class="text-sm text-gray-400">Inactive (180d+)</div>
    </div>
  </div>

  <!-- PC engagement -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
    <div class="bg-gray-800 rounded-lg p-6 border border-gray-700">
      <p class="text-sm text-gray-400">PCs in Events</p>
      <p class="text-2xl font-bold">
        <%= activePcStats.totalInEvents %>
        <span class="text-base font-normal text-gray-400">(<%= activePcStats.totalPcs > 0 ? ((activePcStats.totalInEvents / activePcStats.totalPcs) * 100).toFixed(1) : '0.0' %>%)</span>
      </p>
      <p class="text-xs text-gray-500 mt-1">of <%= activePcStats.totalPcs %> active player PCs</p>
    </div>
    <div class="bg-gray-800 rounded-lg p-6 border border-gray-700">
      <p class="text-sm text-gray-400">Active Players in Events</p>
      <p class="text-2xl font-bold">
        <%= activePcStats.totalActivePlayers %>
        <span class="text-base font-normal text-gray-400">(<%= activePcStats.totalActiveMembers > 0 ? ((activePcStats.totalActivePlayers / activePcStats.totalActiveMembers) * 100).toFixed(1) : '0.0' %>%)</span>
      </p>
      <p class="text-xs text-gray-500 mt-1">of <%= activePcStats.totalActiveMembers %> active players</p>
    </div>
    <div class="bg-gray-800 rounded-lg p-6 border border-gray-700">
      <p class="text-sm text-gray-400">Active Events</p>
      <p id="cardActiveEvents" class="text-2xl font-bold text-green-400"><%= stats.active_events %></p>
    </div>
  </div>

  <!-- Active PCs by Bracket -->
  <div class="bg-gray-800 rounded-lg border border-gray-700 overflow-hidden mb-8">
    <table class="w-full text-left">
      <thead>
        <tr class="text-gray-400 text-sm border-b border-gray-700 bg-gray-800/50">
          <th class="px-4 py-3">Bracket</th>
          <th class="px-4 py-3 text-right">Active PCs</th>
          <th class="px-4 py-3 text-right"># in Events</th>
          <th class="px-4 py-3 text-right">% in Events</th>
          <th class="px-4 py-3 text-right">Days Since Last Event</th>
        </tr>
      </thead>
      <tbody>
        <% activePcStats.rows.forEach(row => { %>
        <%
          const pct = parseFloat(row.pct_in_events);
          let pctClass = 'text-red-400';
          if (pct >= 50) pctClass = 'text-green-400';
          else if (pct >= 25) pctClass = 'text-yellow-400';
        %>
        <tr class="border-b border-gray-700/50 hover:bg-gray-700/30">
          <td class="px-4 py-3 font-semibold"><%= row.bracket %></td>
          <td class="px-4 py-3 text-right"><%= row.active_pcs %></td>
          <td class="px-4 py-3 text-right"><%= row.in_events %></td>
          <td class="px-4 py-3 text-right font-bold <%= pctClass %>"><%= row.pct_in_events %>%</td>
          <td class="px-4 py-3 text-right text-gray-400"><%= row.days_since_last != null ? row.days_since_last : '—' %></td>
        </tr>
        <% }) %>
      </tbody>
      <tfoot>
        <tr class="border-t border-gray-600 bg-gray-800/80 font-bold">
          <td class="px-4 py-3">Total</td>
          <td class="px-4 py-3 text-right"><%= activePcStats.totalPcs %></td>
          <td class="px-4 py-3 text-right"><%= activePcStats.totalInEvents %></td>
          <td class="px-4 py-3 text-right"><%= activePcStats.totalPcs > 0 ? ((activePcStats.totalInEvents / activePcStats.totalPcs) * 100).toFixed(1) : '0.0' %>%</td>
          <td class="px-4 py-3 text-right text-gray-400">
            <% const minDays = activePcStats.rows.filter(r => r.days_since_last != null).map(r => r.days_since_last); %>
            <%= minDays.length > 0 ? Math.min(...minDays) : '—' %>
          </td>
        </tr>
      </tfoot>
    </table>
  </div>

  <!-- PC charts -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">
    <div class="bg-gray-800 rounded-lg p-6 border border-gray-700">
      <h2 class="text-lg font-semibold mb-4">Active PCs vs In Events</h2>
      <canvas id="pcChart"></canvas>
    </div>
    <div class="bg-gray-800 rounded-lg p-6 border border-gray-700">
      <h2 class="text-lg font-semibold mb-4">% in Events by Bracket</h2>
      <canvas id="pctChart"></canvas>
    </div>
  </div>

  <!-- Event Stats section -->
  <div id="event-stats" class="flex flex-wrap items-center justify-between mb-4 gap-4">
    <h2 class="text-xl font-bold">Event Stats</h2>
    <div class="flex flex-wrap items-center gap-2">
      <a href="/#event-stats" data-filter="all" class="px-3 py-1 rounded text-sm <%= activeRange === 'all' ? 'bg-indigo-600 text-white' : 'bg-gray-700 text-gray-300 hover:bg-gray-600' %>">All Time</a>
      <a href="/?range=30d#event-stats" data-filter="30d" class="px-3 py-1 rounded text-sm <%= activeRange === '30d' ? 'bg-indigo-600 text-white' : 'bg-gray-700 text-gray-300 hover:bg-gray-600' %>">Last 30 Days</a>
      <a href="/?range=1y#event-stats" data-filter="1y" class="px-3 py-1 rounded text-sm <%= activeRange === '1y' ? 'bg-indigo-600 text-white' : 'bg-gray-700 text-gray-300 hover:bg-gray-600' %>">Last Year</a>
      <button data-filter="custom" class="px-3 py-1 rounded text-sm <%= activeRange === 'custom' ? 'bg-indigo-600 text-white' : 'bg-gray-700 text-gray-300 hover:bg-gray-600' %>">Custom</button>
    </div>
  </div>

  <!-- Custom Date Range -->
  <div id="customRange" class="<%= activeRange === 'custom' ? '' : 'hidden' %> mb-6">
    <form id="customRangeForm" method="GET" action="/#event-stats" class="flex flex-wrap items-end gap-3">
      <input type="hidden" name="range" value="custom">
      <div>
        <label class="block text-sm text-gray-400 mb-1">From</label>
        <input type="date" name="from" value="<%= customFrom %>" class="bg-gray-800 border border-gray-600 rounded px-3 py-1.5 text-sm text-gray-100 focus:border-indigo-500 focus:outline-none">
      </div>
      <div>
        <label class="block text-sm text-gray-400 mb-1">To</label>
        <input type="date" name="to" value="<%= customTo %>" class="bg-gray-800 border border-gray-600 rounded px-3 py-1.5 text-sm text-gray-100 focus:border-indigo-500 focus:outline-none">
      </div>
      <button type="submit" class="bg-indigo-600 hover:bg-indigo-500 text-white px-4 py-1.5 rounded text-sm">Apply</button>
    </form>
  </div>

  <!-- Event Stat Cards -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    <div class="bg-gray-800 rounded-lg p-4 border border-gray-700">
      <p class="text-sm text-gray-400">Total Events</p>
      <p id="cardTotalEvents" class="text-3xl font-bold"><%= stats.total_events %></p>
    </div>
    <div class="bg-gray-800 rounded-lg p-4 border border-gray-700">
      <p class="text-sm text-gray-400">Completed</p>
      <p id="cardCompletedEvents" class="text-3xl font-bold text-blue-400"><%= stats.completed_events %></p>
    </div>
    <div class="bg-gray-800 rounded-lg p-4 border border-gray-700">
      <p class="text-sm text-gray-400">Unique PCs</p>
      <p id="cardUniquePcs" class="text-3xl font-bold"><%= stats.total_participants %></p>
    </div>
    <div class="bg-gray-800 rounded-lg p-4 border border-gray-700">
      <p class="text-sm text-gray-400">Avg Party Size</p>
      <p id="cardAvgPartySize" class="text-3xl font-bold"><%= parseFloat(stats.avg_party_size).toFixed(1) %></p>
    </div>
  </div>

  <!-- Charts -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">
    <div class="bg-gray-800 rounded-lg p-6 border border-gray-700">
      <h2 class="text-lg font-semibold mb-4">Events by Tier</h2>
      <canvas id="tierChart"></canvas>
    </div>
    <div class="bg-gray-800 rounded-lg p-6 border border-gray-700">
      <h2 class="text-lg font-semibold mb-4">Events by Type</h2>
      <canvas id="typeChart"></canvas>
    </div>
  </div>

  <!-- Most Events Started -->
  <div id="topDmsSection" class="bg-gray-800 rounded-lg p-6 border border-gray-700 <%= stats.top_dms.length === 0 ? 'hidden' : '' %>">
    <h2 class="text-lg font-semibold mb-4">Most Events Started</h2>
    <table class="w-full text-left">
      <thead>
        <tr class="text-gray-400 text-sm border-b border-gray-700">
          <th class="pb-2">DM</th>
          <th class="pb-2">Total Events</th>
        </tr>
      </thead>
      <tbody id="topDmsBody">
        <% stats.top_dms.forEach(dm => { %>
        <tr class="border-b border-gray-700/50">
          <td class="py-2"><%= dm.username ? playerName(dm.username, null) : dm.user_id %></td>
          <td class="py-2"><%= dm.event_count %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</main>

<script>
  Chart.defaults.color = '#9ca3af';

  // ---- Event charts (date-filterable, re-rendered on filter change) ----
  let tierChart = null;
  let typeChart = null;

  function renderTierChart(data) {
    const canvas = document.getElementById('tierChart');
    if (data.length === 0) {
      if (tierChart) { tierChart.destroy(); tierChart = null; }
      return;
    }
    if (tierChart) {
      tierChart.data.labels = data.map(d => d.tier);
      tierChart.data.datasets[0].data = data.map(d => d.count);
      tierChart.update();
    } else {
      tierChart = new Chart(canvas, {
        type: 'bar',
        data: {
          labels: data.map(d => d.tier),
          datasets: [{ label: 'Events', data: data.map(d => d.count), backgroundColor: '#6366f1', borderRadius: 4 }]
        },
        options: {
          plugins: { legend: { display: false } },
          scales: {
            y: { beginAtZero: true, ticks: { stepSize: 1 }, grid: { color: '#1f2937' } },
            x: { grid: { display: false } }
          }
        }
      });
    }
  }

  function renderTypeChart(data) {
    const canvas = document.getElementById('typeChart');
    if (data.length === 0) {
      if (typeChart) { typeChart.destroy(); typeChart = null; }
      return;
    }
    if (typeChart) {
      typeChart.data.labels = data.map(d => d.event_type);
      typeChart.data.datasets[0].data = data.map(d => d.count);
      typeChart.update();
    } else {
      typeChart = new Chart(canvas, {
        type: 'doughnut',
        data: {
          labels: data.map(d => d.event_type),
          datasets: [{ data: data.map(d => d.count), backgroundColor: ['#6366f1', '#8b5cf6', '#a78bfa', '#c4b5fd', '#ddd6fe'] }]
        },
        options: { plugins: { legend: { position: 'bottom' } } }
      });
    }
  }

  // Initial render from server-provided data
  renderTierChart(<%- JSON.stringify(stats.events_by_tier).replace(/</g, '\\u003c') %>);
  renderTypeChart(<%- JSON.stringify(stats.events_by_type).replace(/</g, '\\u003c') %>);

  // ---- PC charts (not date-filterable; one-time render) ----
  const pcData = <%- JSON.stringify(activePcStats.rows).replace(/</g, '\\u003c') %>;
  if (pcData.length > 0) {
    new Chart(document.getElementById('pcChart'), {
      type: 'bar',
      data: {
        labels: pcData.map(d => d.bracket),
        datasets: [
          { label: 'Active PCs', data: pcData.map(d => d.active_pcs), backgroundColor: '#6366f1', borderRadius: 4 },
          { label: 'In Events', data: pcData.map(d => d.in_events), backgroundColor: '#22c55e', borderRadius: 4 }
        ]
      },
      options: {
        plugins: { legend: { position: 'bottom' } },
        scales: {
          y: { beginAtZero: true, grid: { color: '#1f2937' } },
          x: { grid: { display: false } }
        }
      }
    });

    new Chart(document.getElementById('pctChart'), {
      type: 'bar',
      data: {
        labels: pcData.map(d => d.bracket),
        datasets: [{
          label: '% in Events',
          data: pcData.map(d => parseFloat(d.pct_in_events)),
          backgroundColor: pcData.map(d => {
            const pct = parseFloat(d.pct_in_events);
            if (pct >= 50) return '#22c55e';
            if (pct >= 25) return '#eab308';
            return '#ef4444';
          }),
          borderRadius: 4,
        }]
      },
      options: {
        plugins: { legend: { display: false } },
        scales: {
          y: { beginAtZero: true, max: 100, ticks: { callback: v => v + '%' }, grid: { color: '#1f2937' } },
          x: { grid: { display: false } }
        }
      }
    });
  }

  // ---- Client-side filter handling (no page reload) ----
  const ACTIVE_CLASSES = 'px-3 py-1 rounded text-sm bg-indigo-600 text-white';
  const INACTIVE_CLASSES = 'px-3 py-1 rounded text-sm bg-gray-700 text-gray-300 hover:bg-gray-600';

  function escapeHtml(s) {
    return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
  }

  function updateCards(stats) {
    document.getElementById('cardActiveEvents').textContent = stats.active_events;
    document.getElementById('cardTotalEvents').textContent = stats.total_events;
    document.getElementById('cardCompletedEvents').textContent = stats.completed_events;
    document.getElementById('cardUniquePcs').textContent = stats.total_participants;
    document.getElementById('cardAvgPartySize').textContent = parseFloat(stats.avg_party_size).toFixed(1);
  }

  function updateTopDms(top_dms) {
    const section = document.getElementById('topDmsSection');
    const body = document.getElementById('topDmsBody');
    if (top_dms.length === 0) {
      section.classList.add('hidden');
      body.innerHTML = '';
      return;
    }
    section.classList.remove('hidden');
    body.innerHTML = top_dms.map(dm => (
      '<tr class="border-b border-gray-700/50">'
      + '<td class="py-2">' + escapeHtml(dm.display) + '</td>'
      + '<td class="py-2">' + dm.event_count + '</td>'
      + '</tr>'
    )).join('');
  }

  function updateButtons(range) {
    document.querySelectorAll('[data-filter]').forEach(btn => {
      btn.className = btn.dataset.filter === range ? ACTIVE_CLASSES : INACTIVE_CLASSES;
    });
  }

  function buildUrl(range, from, to) {
    const params = new URLSearchParams();
    if (range && range !== 'all') params.set('range', range);
    if (range === 'custom') {
      if (from) params.set('from', from);
      if (to) params.set('to', to);
    }
    const qs = params.toString();
    return '/' + (qs ? '?' + qs : '') + '#event-stats';
  }

  async function applyFilter(range, from, to, { pushState = true } = {}) {
    if (pushState) {
      history.pushState({ range, from, to }, '', buildUrl(range, from, to));
    }
    updateButtons(range);
    document.getElementById('customRange').classList.toggle('hidden', range !== 'custom');

    const apiParams = new URLSearchParams();
    if (range && range !== 'all') apiParams.set('range', range);
    if (range === 'custom') {
      if (from) apiParams.set('from', from);
      if (to) apiParams.set('to', to);
    }
    let res;
    try {
      res = await fetch('/api/stats?' + apiParams.toString());
    } catch (err) {
      console.error('Failed to fetch /api/stats:', err);
      return;
    }
    if (!res.ok) {
      console.error('Stats fetch failed:', res.status);
      return;
    }
    const stats = await res.json();
    updateCards(stats);
    renderTierChart(stats.events_by_tier);
    renderTypeChart(stats.events_by_type);
    updateTopDms(stats.top_dms);
  }

  // Wire up filter buttons
  document.querySelectorAll('[data-filter]').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const range = btn.dataset.filter;
      if (range === 'custom') {
        // Show the custom date form; don't fetch until Apply
        document.getElementById('customRange').classList.toggle('hidden');
        return;
      }
      applyFilter(range, null, null);
    });
  });

  // Wire up custom range form
  document.getElementById('customRangeForm').addEventListener('submit', (e) => {
    e.preventDefault();
    const from = e.target.from.value || null;
    const to = e.target.to.value || null;
    applyFilter('custom', from, to);
  });

  // Back/forward button support
  window.addEventListener('popstate', () => {
    const url = new URL(window.location.href);
    const range = url.searchParams.get('range') || 'all';
    const from = url.searchParams.get('from');
    const to = url.searchParams.get('to');
    applyFilter(range, from, to, { pushState: false });
  });
</script>

<%- include('partials/foot') %>
